dataset/
data/
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.webp

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── OS / editor files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs and temp ────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
