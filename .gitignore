# ── Virtual environment ──────────────────────────────────────────────────────
venv/
env/
.venv/
*.egg-info/

# ── Large data / model files ─────────────────────────────────────────────────
conceptnet/          # ConceptNet NumberBatch (~900 MB) — download separately
cache/               # Pre-computed CLIP embedding caches
models/              # Trained .pt checkpoint files (regenerate with train_phase4.py)

